# Environment
DATABASE_URL=postgresql+asyncpg://asm:asm@localhost:5433/asm
DATABASE_URL_SYNC=postgresql://asm:asm@localhost:5433/asm
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1

# AI (optional — falls back to rule-based analysis)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_ENABLED=true
OLLAMA_HEALTH_CACHE_SECONDS=30

# External scanners (optional — requires naabu/subfinder/nuclei installed)
SCANNER_USE_EXTERNAL_TOOLS=false
SCANNER_NUCLEI_SEVERITY=critical,high,medium
SCANNER_NUCLEI_TAGS=cve
SCANNER_NUCLEI_TIMEOUT=900

# Alerts (optional)
ALERT_SLACK_WEBHOOK=

# Security
SECRET_KEY=change-me-in-production
AUTH_ENABLED=true
API_KEY=
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123
REQUIRE_DOMAIN_VERIFICATION=true
ACCESS_TOKEN_EXPIRE_MINUTES=1440
