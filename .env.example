# Docker Compose host port overrides
POSTGRES_HOST_PORT=5433
API_HOST_PORT=8087
FRONTEND_HOST_PORT=5173

# API secrets — bu dosyayı .gitignore'a ekle, commit'leme
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
AUTH_ENABLED=true
API_KEY=
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123
REQUIRE_DOMAIN_VERIFICATION=true
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEMO_MODE=true
SCAN_COOLDOWN_SECONDS=60

# Tarayıcılar — Docker imajında Nuclei/Naabu/Subfinder hazır gelir
SCANNER_USE_EXTERNAL_TOOLS=true
SCANNER_NUCLEI_SEVERITY=critical,high,medium
SCANNER_NUCLEI_TAGS=cve
SCANNER_NUCLEI_TIMEOUT=900
INSTALL_SCANNERS=true
